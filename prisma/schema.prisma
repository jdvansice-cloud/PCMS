// ═══════════════════════════════════════════════════════════
//  GROOMING
// ═══════════════════════════════════════════════════════════

model GroomingSession {
  id                  String         @id @default(cuid())
  organizationId      String         @map("organization_id")
  branchId            String         @map("branch_id")
  petId               String         @map("pet_id")
  groomerId           String?        @map("groomer_id")
  appointmentId       String?        @unique @map("appointment_id")
  kennelId            String?        @map("kennel_id")
  status              GroomingStatus @default(PENDING)
  scheduledAt         DateTime       @map("scheduled_at")
  startedAt           DateTime?      @map("started_at")
  completedAt         DateTime?      @map("completed_at")
  pickedUpAt          DateTime?      @map("picked_up_at")
  kennelAssignedAt    DateTime?      @map("kennel_assigned_at")
  kennelReleasedAt    DateTime?      @map("kennel_released_at")
  petSize             KennelSize?    @map("pet_size")
  services            String[]
  skinCondition       String?        @map("skin_condition")
  matting             String?
  specialInstructions String?        @map("special_instructions")
  notes               String?
  beforePhotoUrl      String?        @map("before_photo_url")
  afterPhotoUrl       String?        @map("after_photo_url")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id])
  pet          Pet          @relation(fields: [petId], references: [id])
  groomer      User?        @relation("GroomingGroomer", fields: [groomerId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  kennel       Kennel?      @relation(fields: [kennelId], references: [id])

  @@index([organizationId])
  @@index([branchId, scheduledAt])
  @@map("grooming_sessions")
}

// ═══════════════════════════════════════════════════════════
//  KENNEL / HOSPITALIZATION
// ═══════════════════════════════════════════════════════════

model Kennel {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  branchId       String      @map("branch_id")
  name           String
  size           KennelSize  @default(MEDIUM)
  species        Species?
  isAvailable    Boolean     @default(true) @map("is_available")
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id])
  stays        KennelStay[]
  groomingSessions GroomingSession[]
  appointments Appointment[]

  @@map("kennels")
}

model KennelStay {
  id              String     @id @default(cuid())
  organizationId  String     @map("organization_id")
  branchId        String     @map("branch_id")
  kennelId        String     @map("kennel_id")
  petId           String     @map("pet_id")
  reason          String
  admittedAt      DateTime   @map("admitted_at")
  dischargedAt    DateTime?  @map("discharged_at")
  status          StayStatus @default(ACTIVE)
  feedingSchedule String?    @map("feeding_schedule")
  specialCare     String?    @map("special_care")
  notes           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch           @relation(fields: [branchId], references: [id])
  kennel       Kennel           @relation(fields: [kennelId], references: [id])
  pet          Pet              @relation(fields: [petId], references: [id])
  dailyLogs    KennelDailyLog[]

  @@index([organizationId])
  @@map("kennel_stays")
}

model KennelDailyLog {
  id          String   @id @default(cuid())
  stayId      String   @map("stay_id")
  loggedById  String   @map("logged_by_id")
  date        DateTime
  feeding     String?
  medication  String?
  temperature Decimal? @db.Decimal(4, 1)
  weight      Decimal? @db.Decimal(5, 2)
  behavior    String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  stay     KennelStay @relation(fields: [stayId], references: [id], onDelete: Cascade)
  loggedBy User       @relation("KennelLogUser", fields: [loggedById], references: [id])

  @@map("kennel_daily_logs")
}

// ═══════════════════════════════════════════════════════════
//  POS / SALES
// ═══════════════════════════════════════════════════════════

model Sale {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  branchId       String        @map("branch_id")
  ownerId        String?       @map("owner_id")
  appointmentId  String?       @unique @map("appointment_id")
  saleNumber     Int           @map("sale_number")
  subtotal       Decimal       @db.Decimal(10, 2)
  itbms          Decimal       @db.Decimal(10, 2)
  discountAmount Decimal?      @db.Decimal(10, 2) @map("discount_amount")
  discountType   DiscountType? @map("discount_type")
  discountedById String?       @map("discounted_by_id")
  total          Decimal       @db.Decimal(10, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(10, 2) @map("balance_due")
  status         SaleStatus    @default(COMPLETED)
  isOnlineSale   Boolean       @default(false) @map("is_online_sale")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id])
  owner        Owner?        @relation(fields: [ownerId], references: [id])
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id])
  discountedBy User?         @relation("SaleDiscounter", fields: [discountedById], references: [id])
  lines        SaleLine[]
  payments     SalePayment[]
  refunds      Refund[]
  promotions   SalePromotion[]
  giftCardTxs  GiftCardTx[]
  loyaltyTxs   LoyaltyLedger[]

  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@map("sales")
}

model SaleLine {
  id             String        @id @default(cuid())
  saleId         String        @map("sale_id")
  productId      String?       @map("product_id")
  serviceId      String?       @map("service_id")
  description    String
  quantity       Int           @default(1)
  unitPrice      Decimal       @db.Decimal(10, 2) @map("unit_price")
  discountAmount Decimal?      @db.Decimal(10, 2) @map("discount_amount")
  discountType   DiscountType? @map("discount_type")
  giftCardProductId String?       @map("gift_card_product_id")
  isTaxExempt       Boolean       @default(false) @map("is_tax_exempt")
  isInvoiceable     Boolean       @default(true) @map("is_invoiceable")
  subtotal          Decimal       @db.Decimal(10, 2)
  itbms             Decimal       @db.Decimal(10, 2)
  lineTotal         Decimal       @db.Decimal(10, 2) @map("line_total")

  sale            Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
  service         Service?         @relation(fields: [serviceId], references: [id])
  giftCardProduct GiftCardProduct? @relation(fields: [giftCardProductId], references: [id])
  promoLinks      SalePromotion[]

  @@map("sale_lines")
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String        @map("sale_id")
  paymentMethod PaymentMethod @map("payment_method")
  amount        Decimal       @db.Decimal(10, 2)
  reference     String?
  paidAt        DateTime      @default(now()) @map("paid_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model Refund {
  id            String   @id @default(cuid())
  saleId        String   @map("sale_id")
  amount        Decimal  @db.Decimal(10, 2)
  reason        String?
  processedById String   @map("processed_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  sale        Sale @relation(fields: [saleId], references: [id])
  processedBy User @relation("RefundProcessor", fields: [processedById], references: [id])

  @@map("refunds")
}

// ═══════════════════════════════════════════════════════════
//  GIFT CARDS
// ═══════════════════════════════════════════════════════════

model GiftCard {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  code           String
  initialBalance Decimal        @db.Decimal(10, 2) @map("initial_balance")
  balance        Decimal        @db.Decimal(10, 2)
  status         GiftCardStatus @default(ACTIVE)
  validFrom      DateTime       @default(now()) @map("valid_from")
  expiresAt      DateTime?      @map("expires_at")
  purchasedById  String?        @map("purchased_by_id")
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchasedBy  Owner?       @relation(fields: [purchasedById], references: [id])
  transactions GiftCardTx[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@map("gift_cards")
}

model GiftCardTx {
  id           String   @id @default(cuid())
  giftCardId   String   @map("gift_card_id")
  saleId       String?  @map("sale_id")
  amount       Decimal  @db.Decimal(10, 2)
  type         String   // PURCHASE, TOP_UP, REDEMPTION, REFUND
  balanceAfter Decimal  @db.Decimal(10, 2) @map("balance_after")
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  giftCard  GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  sale      Sale?    @relation(fields: [saleId], references: [id])
  createdBy User     @relation("GiftCardTxCreator", fields: [createdById], references: [id])

  @@index([giftCardId, createdAt])
  @@map("gift_card_transactions")
}

model GiftCardProduct {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  amount         Decimal  @db.Decimal(10, 2)
  expirationDays Int?     @map("expiration_days")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saleLines    SaleLine[]

  @@index([organizationId, isActive])
  @@map("gift_card_products")
}

// ═══════════════════════════════════════════════════════════
//  PROMOTIONS
// ═══════════════════════════════════════════════════════════

model Promotion {
  id               String        @id @default(cuid())
  organizationId   String        @map("organization_id")
  name             String
  type             PromotionType
  value            Decimal       @db.Decimal(10, 2)
  minPurchase      Decimal?      @db.Decimal(10, 2) @map("min_purchase")
  maxDiscount      Decimal?      @db.Decimal(10, 2) @map("max_discount")
  usageLimit       Int?          @map("usage_limit")
  usageCount       Int           @default(0) @map("usage_count")
  perCustomerLimit Int?          @map("per_customer_limit")
  startsAt         DateTime      @map("starts_at")
  endsAt           DateTime      @map("ends_at")
  isActive         Boolean       @default(true) @map("is_active")
  appliesToAll     Boolean       @default(true) @map("applies_to_all")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Buy X Get Y fields
  triggerProductId   String?       @map("trigger_product_id")
  triggerServiceId   String?       @map("trigger_service_id")
  rewardProductId    String?       @map("reward_product_id")
  rewardServiceId    String?       @map("reward_service_id")
  rewardDiscount     Decimal?      @db.Decimal(10, 2) @map("reward_discount")
  rewardDiscountUnit DiscountUnit? @map("reward_discount_unit")

  // Bundle fields
  bundlePrice Decimal? @db.Decimal(10, 2) @map("bundle_price")

  // Online availability
  availableOnline Boolean @default(false) @map("available_online")

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggerProduct   Product?              @relation("PromoTrigger", fields: [triggerProductId], references: [id])
  triggerService   Service?              @relation("PromoTriggerSvc", fields: [triggerServiceId], references: [id])
  rewardProduct    Product?              @relation("PromoReward", fields: [rewardProductId], references: [id])
  rewardService    Service?              @relation("PromoRewardSvc", fields: [rewardServiceId], references: [id])
  includedProducts PromotionProduct[]
  includedServices PromotionService[]
  volumeTiers      PromotionVolumeTier[]
  sales            SalePromotion[]

  @@index([organizationId, isActive, startsAt, endsAt])
  @@map("promotions")
}

model PromotionProduct {
  promotionId String @map("promotion_id")
  productId   String @map("product_id")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

model PromotionService {
  promotionId String @map("promotion_id")
  serviceId   String @map("service_id")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([promotionId, serviceId])
  @@map("promotion_services")
}

model PromotionVolumeTier {
  id           String       @id @default(cuid())
  promotionId  String       @map("promotion_id")
  tierOrder    Int          @map("tier_order")
  minQty       Int          @map("min_qty")
  maxQty       Int?         @map("max_qty")
  discount     Decimal      @db.Decimal(10, 2)
  discountUnit DiscountUnit @map("discount_unit")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, tierOrder])
  @@map("promotion_volume_tiers")
}

model SalePromotion {
  id             String  @id @default(cuid())
  saleId         String  @map("sale_id")
  promotionId    String  @map("promotion_id")
  saleLineId     String? @map("sale_line_id")
  discountAmount Decimal @db.Decimal(10, 2) @map("discount_amount")

  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])
  saleLine  SaleLine? @relation(fields: [saleLineId], references: [id])

  @@map("sale_promotions")
}

// ═══════════════════════════════════════════════════════════
//  CUSTOMER PROMOTIONS (loyalty-based, tracks purchase history)
// ═══════════════════════════════════════════════════════════

enum CustomerPromotionItemRole {
  QUALIFYING
  REWARD
}

model CustomerPromotion {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  name            String
  description     String?
  threshold       Int
  isRecurring     Boolean  @default(true) @map("is_recurring")
  isActive        Boolean  @default(true) @map("is_active")
  availableOnline Boolean  @default(false) @map("available_online")
  startsAt        DateTime @map("starts_at")
  endsAt          DateTime @map("ends_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        CustomerPromotionItem[]
  progress     CustomerPromotionProgress[]

  @@index([organizationId, isActive])
  @@map("customer_promotions")
}

model CustomerPromotionItem {
  id                  String                    @id @default(cuid())
  customerPromotionId String                    @map("customer_promotion_id")
  role                CustomerPromotionItemRole
  productId           String?                   @map("product_id")
  serviceId           String?                   @map("service_id")

  customerPromotion CustomerPromotion @relation(fields: [customerPromotionId], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  service           Service?          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("customer_promotion_items")
}

model CustomerPromotionProgress {
  id                  String   @id @default(cuid())
  customerPromotionId String   @map("customer_promotion_id")
  ownerId             String   @map("owner_id")
  currentCount        Int      @default(0) @map("current_count")
  totalEarned         Int      @default(0) @map("total_earned")
  totalRedeemed       Int      @default(0) @map("total_redeemed")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customerPromotion CustomerPromotion @relation(fields: [customerPromotionId], references: [id], onDelete: Cascade)
  owner             Owner             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([customerPromotionId, ownerId])
  @@map("customer_promotion_progress")
}

// ═══════════════════════════════════════════════════════════
//  LOYALTY PROGRAM
// ═══════════════════════════════════════════════════════════

model LoyaltyConfig {
  id             String   @id @default(cuid())
