// ═══════════════════════════════════════════════════════════
//  GROOMING CONFIG & BOOKING
// ═══════════════════════════════════════════════════════════

model GroomingConfig {
  id                     String   @id @default(cuid())
  organizationId         String   @unique @map("organization_id")
  isOnlineBookingEnabled Boolean  @default(true) @map("is_online_booking_enabled")
  maxAdvanceDays         Int      @default(7) @map("max_advance_days")
  pickupCutoffTime       String   @default("06:00") @map("pickup_cutoff_time")
  receivingCutoffTime    String   @default("14:00") @map("receiving_cutoff_time")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("grooming_config")
}

model GroomingPickup {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  branchId       String       @map("branch_id")
  appointmentId  String       @unique @map("appointment_id")
  address        String
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  status         PickupStatus @default(REQUESTED)
  pickupTime     String?      @map("pickup_time")
  pickupDate     DateTime     @map("pickup_date")
  pickedUpAt     DateTime?    @map("picked_up_at")
  deliveryTime   String?      @map("delivery_time")
  deliveredAt    DateTime?    @map("delivered_at")
  routeOrder     Int?         @map("route_order")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id])
  appointment  Appointment  @relation(fields: [appointmentId], references: [id])

  @@index([branchId, pickupDate])
  @@map("grooming_pickups")
}

// ═══════════════════════════════════════════════════════════
//  AUDIT LOG
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  userId         String?     @map("user_id")
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String      @map("entity_id")
  changes        Json?
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
