  dollarRate     Decimal  @db.Decimal(10, 4) @map("dollar_rate")
  expirationDays Int?     @map("expiration_days")
  minRedemption  Decimal  @default(1) @db.Decimal(10, 2) @map("min_redemption")
  updatedAt      DateTime @updatedAt @map("updated_at")

